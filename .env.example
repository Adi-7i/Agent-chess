# Server Configuration
PORT=4000
CLIENT_URL=http://localhost:3000

# Shared OpenAI-compatible configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODELS=Kimi-K2.5,DeepSeek-V3.1,gpt-oss-120b,DeepSeek-R1-0528,DeepSeek-R1

# LLM_X Configuration
LLM_X_API_KEY=
LLM_X_ENDPOINT=
LLM_X_MODEL=Kimi-K2.5

# LLM_Y Configuration
LLM_Y_API_KEY=
LLM_Y_ENDPOINT=
LLM_Y_MODEL=DeepSeek-R1

# Backward-compatible aliases (optional)
LLM1_API_KEY=
LLM1_ENDPOINT=
LLM1_MODEL=
LLM2_API_KEY=
LLM2_ENDPOINT=
LLM2_MODEL=

# LLM API Timeout (milliseconds)
LLM_TIMEOUT=15000

# Optional: raise for reasoning-heavy models that emit long analysis before move
LLM_MAX_TOKENS=512

# Examples for different providers:

# OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODELS=Kimi-K2.5,DeepSeek-R1

# Anthropic Claude:
# LLM_Y_ENDPOINT=https://api.anthropic.com/v1/messages
# LLM_Y_MODEL=claude-3-5-sonnet-latest

# Ollama (local):
# LLM_X_ENDPOINT=http://localhost:11434/api/generate
# LLM_X_MODEL=llama3
