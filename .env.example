# Server Configuration
PORT=4000
CLIENT_URL=http://localhost:3000

# LLM_X Configuration
LLM_X_API_KEY=
LLM_X_ENDPOINT=
LLM_X_MODEL=gpt-4o-mini

# LLM_Y Configuration
LLM_Y_API_KEY=
LLM_Y_ENDPOINT=
LLM_Y_MODEL=gpt-4o-mini

# Backward-compatible aliases (optional)
LLM1_API_KEY=
LLM1_ENDPOINT=
LLM1_MODEL=
LLM2_API_KEY=
LLM2_ENDPOINT=
LLM2_MODEL=

# LLM API Timeout (milliseconds)
LLM_TIMEOUT=15000

# Examples for different providers:

# OpenAI:
# LLM_X_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_X_MODEL=gpt-4o-mini

# Anthropic Claude:
# LLM_Y_ENDPOINT=https://api.anthropic.com/v1/messages
# LLM_Y_MODEL=claude-3-5-sonnet-latest

# Ollama (local):
# LLM_X_ENDPOINT=http://localhost:11434/api/generate
# LLM_X_MODEL=llama3
